  "instructions_to_main_agent": [
    "1. IMPLEMENTATION PRIORITY: Mobile First. Focus on the 'Feed' and 'Calculator' experience.",
    "2. THEME: Force Dark Mode. Do not implement a Light Mode toggle unless explicitly requested for accessibility.",
    "3. HEADER: The Daily Rates must be visible immediately. Use a 'Ticker' or 'Sticky Header' approach.",
    "4. IMAGES: Use 'aspect-square' for product grids and 'aspect-[4/5]' for detail views.",
    "5. DATA: Mock the Silver/Gold rates with realistic fluctuations for the demo.",
    "6. ADMIN: The dashboard must look like a 'Trading Terminal' - dense data, clear charts, no fluff.",
    "7. UNIVERSAL GUIDELINES: Follow the 'Anti-AI' rules - no generic purple gradients, no centered text everywhere."
  ],
  "universal_guidelines": {
    "dos": [
      "Use Z-index layers to create depth (Background > Glow > Card > Content)",
      "Use specific transitions: 'transition-transform duration-300 ease-out'",
      "Use 'backdrop-blur' for overlays to maintain context"
    ],
    "donts": [
      "No default blue/purple generic SaaS colors",
      "No 'text-gray-500' on dark mode (use 'text-white/60' for better blending)",
      "No skeletal loaders that look broken (use subtle shimmer)"
    ]
  }
